meta {
  name: Thesis by Career
  type: http
  seq: 2
}

get {
  url: http://localhost:8000/api/reports/theses-by-career
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Returns data array", function() {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("array");
  });
  test("Each item has name and theses_count", function() {
    if (res.body.data.length > 0) {
      expect(res.body.data[0]).to.have.property("name");
      expect(res.body.data[0]).to.have.property("theses_count");
    }
  });
}
