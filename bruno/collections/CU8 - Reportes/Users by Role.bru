meta {
  name: Users by Role
  type: http
  seq: 6
}

get {
  url: http://localhost:8000/api/reports/users-by-role
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Returns data array", function() {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("array");
  });
  test("Each item has user_type and total", function() {
    if (res.body.data.length > 0) {
      expect(res.body.data[0]).to.have.property("user_type");
      expect(res.body.data[0]).to.have.property("total");
    }
  });
}
